<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:orientation="vertical"
    tools:context=".fragmentAsistente">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/txtRegistroGlucemia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asistente de Dosis"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- INFO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A partir de tus registros más recientes, calculamos la dosis recomendada."
            android:background="@drawable/bg_info"
            android:padding="12dp"
            android:textColor="#555"
            android:layout_marginBottom="16dp"/>

        <!-- RESUMEN -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resumen de tus últimos registros"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginRight="20dp"
            android:layout_marginLeft="20dp"
            android:layout_marginBottom="8dp"/>


        <TableRow
            android:id="@+id/trResumenGlucemia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtGlucemiaResumen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Glucemia (mg/dL):" />

                <TextView
                    android:id="@+id/txtGlucemiaR"
                    android:layout_width="189dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="mg/dL" />

        </TableRow>

        <TableRow
            android:id="@+id/trCarbohidratosResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtCarbohidratos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/txtGlucemia"
                    android:padding="8dp"
                    android:text="Carbohidratos:" />

                <TextView
                    android:id="@+id/txtComidaR"
                    android:layout_width="233dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="(gr)" />

        </TableRow>

        <TableRow
            android:id="@+id/trEstacionResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtEstacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estación alimenticia:"
                    android:padding="8dp"/>

                <TextView
                    android:id="@+id/txtEstAlimenticiaR"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center|end"
                    android:text="" />
        </TableRow>

        <!-- CÁLCULO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cálculo de la dosis"
            android:layout_marginRight="20dp"
            android:layout_marginLeft="20dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <TableRow
            android:id="@+id/trCalculoDosisCarbo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtDosisCarbo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosis por carbohidratos:"
                    android:padding="6dp"/>

                <TextView
                    android:id="@+id/txtDosisCarboR"
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

                <TextView
                    android:id="@+id/textView4"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="(u)" />


        </TableRow>

        <TableRow
            android:id="@+id/trCalculoDosisGlucemia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtTipoDeInsulina"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtDosisCorreccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosis por corrección:"
                    android:padding="6dp"/>

                <TextView
                    android:id="@+id/txtDosisCorrecionR"
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="(u)" />

        </TableRow>

        <!-- RESULTADO FINAL -->
        <TableRow
            android:id="@+id/trCalculoDosisGlucemia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtTipoDeInsulina"
            android:background="@drawable/bg_resultado"
            android:layout_marginTop="5dp">

                <TextView
                    android:id="@+id/txtDosisTotal"
                    android:layout_width="235dp"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:padding="10dp"
                    android:text="Dosis total:"
                    android:textColor="#2E7D32"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDosisFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center|end"
                    android:layout_marginRight="3dp"
                    android:textColor="#2E7D32"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:text="" />

                <TextView
                    android:id="@+id/textView9"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#2E7D32"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:text="(u)" />

        </TableRow>

        <!-- INFO EXTRA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Información adicional"
            android:textStyle="bold"
            android:layout_marginRight="20dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <TableRow
            android:id="@+id/trRelacionInsuCarbo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtTipoDeInsulina"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtRelacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Relación insulina/carbohidratos:"
                    android:padding="6dp"/>

                <TextView
                    android:id="@+id/txtRelacionInsuHidrato"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

        </TableRow>

        <TableRow
            android:id="@+id/trRelacionInsuCarbo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp">

                <TextView
                    android:id="@+id/txtFactorCorreccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Factor de corrección:"
                    android:padding="6dp" />

                <TextView
                    android:id="@+id/txtFactorCorreccionR"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="3dp"
                    android:gravity="center|end"
                    android:text="" />

        </TableRow>

        <!-- BOTONES -->
        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular dosis"
            android:backgroundTint="#5E60CE"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"/>

        <Button
            android:id="@+id/btnActualizar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actualizar cálculo"
            android:layout_gravity="center"/>


</LinearLayout>
